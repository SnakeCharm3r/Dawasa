            text-decoration: none;
            padding: 15px 30px;
            border-radius: 6px;
            font-weight: 600;
            margin: 20px 0;
        }
        .footer {
            background-color: #0B2C6E;
            color: white;
            padding: 30px;
            text-align: center;
            font-size: 12px;
        }
        .footer a {
            color: white;
            text-decoration: underline;
        }
